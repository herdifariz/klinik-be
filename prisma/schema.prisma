generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  DOCTOR
  STAFF
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  E_WALLET
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  O_POSITIVE
  O_NEGATIVE
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique @db.VarChar(255)
  password  String    @db.Text
  fullName  String    @db.VarChar(255)
  role      UserRole  @default(DOCTOR)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  doctor         Doctor?
  medicalRecords MedicalRecord[]
  auditLogs      AuditLog[]

  @@index([email])
  @@index([role])
}

// ============================================
// PATIENT
// ============================================

model Patient {
  id                    String     @id @default(cuid())
  fullName              String     @db.VarChar(255)
  email                 String?    @db.VarChar(255)
  medicalId             String     @unique @db.VarChar(50)
  nik                   String     @unique @db.VarChar(16)
  dateOfBirth           DateTime
  gender                Gender?
  phone                 String     @db.VarChar(20)
  address               String     @db.Text
  city                  String     @db.VarChar(100)
  province              String     @db.VarChar(100)
  postalCode            String?    @db.VarChar(10)
  emergencyContactName  String     @db.VarChar(255)
  emergencyContactPhone String     @db.VarChar(20)
  allergies             String[]   @default([])
  bloodType             BloodType?
  medicalHistory        String?    @db.Text
  chronicDiseases       String[]   @default([])
  currentMedications    String[]   @default([])
  notes                 String?    @db.Text
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]
  payments       Payment[]

  @@index([medicalId])
  @@index([phone])
}

// ============================================
// DOCTOR
// ============================================

model Doctor {
  id                String   @id @default(cuid())
  userId            String   @unique
  licenseNumber     String   @unique @db.VarChar(50)
  specialization    String   @db.VarChar(100)
  experience        Int      @default(0) // Years
  biography         String?  @db.Text
  consultationFee   Float    @default(0)
  rating            Decimal? @default(0) @db.Decimal(2, 1)
  totalRatings      Int      @default(0)
  isAvailable       Boolean  @default(true)
  workingDaysStart  String?  @db.VarChar(10) // e.g., "Monday"
  workingDaysEnd    String?  @db.VarChar(10) // e.g., "Friday"
  workingHoursStart String?  @db.VarChar(5) // e.g., "08:00"
  workingHoursEnd   String?  @db.VarChar(5) // e.g., "17:00"
  breakTimeStart    String?  @db.VarChar(5)
  breakTimeEnd      String?  @db.VarChar(5)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  schedules     DoctorSchedule[]
  prescriptions Prescription[]

  @@index([userId])
  @@index([specialization])
}

// ============================================
// DOCTOR SCHEDULE
// ============================================

model DoctorSchedule {
  id              String   @id @default(cuid())
  doctorId        String
  dayOfWeek       String   @db.VarChar(10) // Monday-Sunday
  startTime       String   @db.VarChar(5) // HH:MM
  endTime         String   @db.VarChar(5) // HH:MM
  slotDuration    Int      @default(30) // Minutes
  maxAppointments Int      @default(10)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
}

// ============================================
// APPOINTMENT
// ============================================

model Appointment {
  id                  String            @id @default(cuid())
  patientId           String
  doctorId            String
  appointmentDateTime DateTime
  status              AppointmentStatus @default(SCHEDULED)
  reason              String            @db.Text
  notes               String?           @db.Text
  consultationNotes   String?           @db.Text // Filled by doctor after appointment
  actualDuration      Int? // Minutes (recorded after appointment)
  reminderSent        Boolean           @default(false)
  reminderSentAt      DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  cancelledAt         DateTime?
  cancelledBy         String? // userId who cancelled
  cancellationReason  String?           @db.Text

  // Relations
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  medicalRecord MedicalRecord?
  prescriptions Prescription[]
  payment       Payment?

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([appointmentDateTime])
}

// ============================================
// MEDICAL RECORD
// ============================================

model MedicalRecord {
  id               String    @id @default(cuid())
  appointmentId    String    @unique
  patientId        String
  doctorId         String?
  diagnosis        String    @db.Text
  treatment        String    @db.Text
  medications      String[]  @default([])
  investigations   String?   @db.Text // Lab tests, etc.
  followUpRequired Boolean   @default(false)
  followUpDate     DateTime?
  notes            String?   @db.Text
  documentUrl      String?   @db.Text // For medical documents/reports
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      User?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([patientId])
  @@index([doctorId])
}

// ============================================
// MEDICINE
// ============================================

model Medicine {
  id                String    @id @default(cuid())
  code              String    @unique @db.VarChar(50)
  name              String    @db.VarChar(255)
  genericName       String?   @db.VarChar(255)
  category          String    @db.VarChar(100)
  description       String?   @db.Text
  dosage            String    @db.VarChar(100) // e.g., "500mg", "100ml"
  form              String    @db.VarChar(50) // tablet, capsule, syrup, etc.
  manufacturer      String    @db.VarChar(255)
  stock             Int       @default(0)
  minStock          Int       @default(10)
  unitPrice         Float     @default(0)
  expiryDate        DateTime?
  batchNumber       String?   @db.VarChar(100)
  sideEffects       String[]  @default([])
  contraindications String[]  @default([])
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  prescriptionItems PrescriptionItem[]

  @@index([code])
  @@index([name])
  @@index([category])
}

// ============================================
// PRESCRIPTION
// ============================================

model Prescription {
  id               String   @id @default(cuid())
  appointmentId    String
  patientId        String
  doctorId         String
  prescriptionDate DateTime @default(now())
  validityEndDate  DateTime
  status           String   @default("active") // active, completed, cancelled
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  appointment Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor             @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  items       PrescriptionItem[]

  @@index([appointmentId])
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

// ============================================
// PRESCRIPTION ITEM
// ============================================

model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  medicineId     String
  dosage         String   @db.VarChar(100) // e.g., "1 tablet"
  frequency      String   @db.VarChar(50) // e.g., "2x daily"
  duration       String   @db.VarChar(50) // e.g., "7 days"
  quantity       Int      @default(1)
  instructions   String?  @db.Text
  createdAt      DateTime @default(now())

  // Relations
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine     Medicine     @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@index([prescriptionId])
  @@index([medicineId])
}

// ============================================
// PAYMENT & BILLING
// ============================================

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  patientId       String
  amount          Float
  paidAmount      Float         @default(0)
  discountAmount  Float         @default(0)
  discountReason  String?       @db.VarChar(255)
  taxAmount       Float         @default(0)
  totalAmount     Float
  status          PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  transactionId   String?       @unique @db.VarChar(100)
  referenceNumber String?       @unique @db.VarChar(100)
  paidAt          DateTime?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([patientId])
  @@index([status])
  @@index([paidAt])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   @db.VarChar(100) // CREATE, READ, UPDATE, DELETE
  entityType String   @db.VarChar(100) // Patient, Doctor, Appointment, etc.
  entityId   String   @db.VarChar(100)
  changes    String?  @db.Text // JSON string of changes
  ipAddress  String?  @db.VarChar(50)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
